generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(uuid()) 
  email         String       @unique
  password      String
  role          String       @default("DONOR")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  donor         Donor?
  staff         Staff?
}

model Donor {
  id                 String        @id @default(uuid()) 
  userId             String        @unique
  firstName          String
  lastName           String
  phone              String?
  dateOfBirth        DateTime
  gender             String
  bloodType          String?
  address            String?
  city               String?
  state              String?
  weight             Float?
  eligibilityStatus  Boolean       @default(true)
  lastDonationDate   DateTime?
  medicalConditions  String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  user               User          @relation(fields: [userId], references: [id])
  appointments       Appointment[]
  donations          Donation[]
  bloodUnits         BloodUnit[]
  screenings         HealthScreening[]
}

model Staff {
  id              String        @id @default(uuid()) 
  userId          String        @unique
  firstName       String
  lastName        String
  department      String?
  hospitalName    String?
  bloodBankName   String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id])
}

model BloodUnit {
  id              String        @id @default(uuid()) 
  unitNumber      String        @unique
  bloodType       String
  bloodGroup      String
  component       String
  volume          Float
  collectedDate   DateTime
  expiryDate      DateTime
  status          String        @default("COLLECTED")
  storageLocation String?
  collectedFromId String?
  collectedFrom   Donor?        @relation(fields: [collectedFromId], references: [id])
  collectedById   String?
  testedById      String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  reservations    Reservation[]
  issuances       Issuance[]
}

model Appointment {
  id              String        @id @default(uuid()) 
  donorId         String
  bloodBankId     String?
  appointmentDate DateTime
  startTime       String
  endTime         String
  status          String        @default("SCHEDULED")
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  donor           Donor        @relation(fields: [donorId], references: [id])
}

model Donation {
  id              String        @id @default(uuid()) 
  donorId         String
  bloodUnitId     String
  donationDate    DateTime
  volume          Float
  screeningResult String
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  donor           Donor        @relation(fields: [donorId], references: [id])
}

model BloodRequest {
  id               String        @id @default(uuid()) 
  hospitalId       String?
  patientName      String?
  patientContact   String?
  requesterRelation String?
  requestedById     String
  bloodType        String
  quantity         Int
  priority         String        @default("NORMAL")
  status           String        @default("PENDING")
  requiredDate     DateTime?
  notes            String?
  fulfillmentDate  DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  reservations     Reservation[]
}

model Reservation {
  id              String        @id @default(uuid()) 
  bloodRequestId  String
  bloodUnitId     String
  reservedAt      DateTime      @default(now())
  releasedAt      DateTime?
  status          String        @default("ACTIVE")
  bloodRequest    BloodRequest  @relation(fields: [bloodRequestId], references: [id])
  bloodUnit       BloodUnit     @relation(fields: [bloodUnitId], references: [id])
}

model Issuance {
  id              String        @id @default(uuid()) 
  bloodUnitId     String
  bloodRequestId  String?
  issuedTo        String
  issuedAt        DateTime      @default(now())
  issuedById      String?
  notes           String?
  bloodUnit       BloodUnit     @relation(fields: [bloodUnitId], references: [id])
}

model Notification {
  id              String        @id @default(uuid()) 
  userId          String
  type            String
  title           String
  message         String
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model AuditLog {
  id              String        @id @default(uuid()) 
  userId          String
  action          String
  entityType      String
  entityId        String?
  details         String?
  ipAddress       String?
  userAgent       String?
  createdAt       DateTime      @default(now())
}

model HealthScreening {
  id                    String   @id @default(uuid())
  donorId               String
  haemoglobinLevel      Float?
  bloodPressureSystolic Int?
  bloodPressureDiastolic Int?
  heartRate             Int?
  bodyTemperature       Float?
  bloodSugarLevel       Float?
  weight                Float?
  notes                 String?
  screeningDate         DateTime @default(now())
  createdAt             DateTime @default(now())
  donor                 Donor    @relation(fields: [donorId], references: [id])
}

model AppointmentSlot {
  id              String        @id @default(uuid()) 
  bloodBankId     String
  date            DateTime
  startTime       String
  endTime         String
  capacity        Int           @default(10)
  available       Int           @default(10)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
}
